{
  "name": "contest-fullstack",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n server,client -c amber,cyan \"npm run dev -w server\" \"npm run dev -w client\"",
    "db:init": "npm run db:init -w server",
    "build": "npm run build -w client",
    "start": "npm run start -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
